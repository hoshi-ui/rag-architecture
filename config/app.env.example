# RAG System Configuration
#
# 环境配置
#
# ==================== 应用配置 ====================
APP_NAME=RAG-System
APP_PORT=8080
DEBUG=true
LOG_LEVEL=INFO
#
# ==================== Milvus 配置 ====================
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=minioadmin
MILVUS_PASSWORD=minioadmin
MILVUS_SECURE=false
#
# ==================== 服务配置 ====================
EMBEDDING_SERVICE_URL=http://embedding-service:8000
RERANK_SERVICE_URL=http://rerank-service:8000
OCR_SERVICE_URL=http://host.docker.internal:8010/api/ocr_text
OCR_MODE=general
OCR_LANG=auto
OCR_TIMEOUT=60
OCR_SHARED_CONTAINER_DIR=/ocr-bridge
OCR_SHARED_HOST_DIR=/home/hongjun/rag-architecture/ocr-bridge
PDF_OCR_MAX_TEXT_CHARS_PER_PAGE=300
#
# ==================== LLM 配置 ====================
LLM_PROVIDER=openai
LLM_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
LLM_API_BASE=http://192.168.30.84:8000/v1
LLM_API_KEY=
LLM_CHAT_COMPLETIONS_URL=
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.6
LLM_TOP_P=0.95
LLM_MAX_TOKENS=500
LLM_PRESENCE_PENALTY=1.5
LLM_EXTRA_BODY={"top_k":40,"chat_template_kwargs":{"enable_thinking":false}}
#
# ==================== 系统配置 ====================
CHUNK_SIZE=500
OVERLAP=100
TOP_K=50
RERANK_TOP_K=10
ENABLE_RERANK=true
MIN_RELEVANCE_SCORE=0.25
MIN_EVIDENCE_SCORE=0.6
MIN_SUBSTANTIVE_CHUNKS=1
MIN_RESCUE_SCORE=0.48
PRIMARY_EVIDENCE_TOPK=5
RESCUE_EVIDENCE_TOPK=15
ALLOW_GUARDED_FULL=true
RECALL_TOP_K=20
RECALL_RELATIVE_SCORE_RATIO=0.72
RECALL_MIN_KEEP_N=3
FINAL_CONTEXT_N=10
FINAL_CONTEXT_N_MAX=10
CONTEXT_MAX_CHARS=8000
CONTEXT_DOC_MAX_CHARS=1200
EVIDENCE_MAX_TOKENS=6500
HYBRID_STRUCT_W_SECTION_TERM=0.24
HYBRID_STRUCT_W_TEXT_TERM=0.18
HYBRID_STRUCT_W_SECTION_OVERLAP=0.22
HYBRID_STRUCT_W_KEYWORD=0.18
HYBRID_STRUCT_W_TITLE=0.10
HYBRID_STRUCT_W_BASE=0.08
HYBRID_STRUCT_FOLLOW_BONUS=0.16
HYBRID_STRUCT_FOLLOW_WINDOW=3
HYBRID_STRUCT_GENERIC_PENALTY=0.18
HYBRID_STRUCT_SECTION_MATCH_BONUS=0.22
HYBRID_STRUCT_SECTION_MISMATCH_PENALTY=0.12
#
# ==================== 安全配置 ====================
ACCESS_CONTROL_ENABLED=true
PII_DETECTION_ENABLED=true
